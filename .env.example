# Copy to .env (which is gitignored) and fill in real values.
#
# To get the Gmail app password:
#   1. Enable 2-Step Verification on the From account:
#      https://myaccount.google.com/security
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Pick "Mail", any device name. Copy the 16-char password (no spaces).
#
# Then test:  python3 -m bot.notifier --test

EMAIL_FROM=bollapranav05@gmail.com
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_TO=bollapranav05@gmail.com

# Wallet trade alerts — comma-separated username:wallet pairs.
# Add or remove users here; restart wallet_alerts to pick up changes.
WALLET_ALERTS=matanovik:0x39d3c773be30fcc73161fc6768f46d563a779ef0

# Legacy single-user vars (used only if WALLET_ALERTS is unset):
# WALLET_ALERT_USERNAME=matanovik
# WALLET_ALERT_WALLET=0x39d3c773be30fcc73161fc6768f46d563a779ef0
